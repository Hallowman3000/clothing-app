# --- App ---
# Public URL used for canonical links, API callbacks, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Newsletter integration (server-only) ---
# Keep secret values only in local `.env.local` or deployment secret manager.
NEWSLETTER_API_KEY=replace-with-your-newsletter-provider-key
NEWSLETTER_AUDIENCE_ID=replace-with-your-audience-id
NEWSLETTER_API_BASE_URL=https://api.your-provider.com

# --- Optional analytics (public) ---
NEXT_PUBLIC_ANALYTICS_ID=
